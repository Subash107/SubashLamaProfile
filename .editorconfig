root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,html,css,js,json,yml,yaml,conf}]
end_of_line = lf
indent_style = space

[*.md]
trim_trailing_whitespace = false

[*.{html,js,json,yml,yaml,conf}]
indent_size = 2

[*.css]
indent_size = 4

[*.ps1]
end_of_line = crlf
indent_style = space
indent_size = 2
