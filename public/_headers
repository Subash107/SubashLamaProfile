/*
  # Security headers — applied to ALL responses via Cloudflare Pages
  # _headers file: https://developers.cloudflare.com/pages/configuration/headers/

  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), serial=(), midi=(), magnetometer=(), gyroscope=(), accelerometer=(), ambient-light-sensor=()
  Cross-Origin-Resource-Policy: same-origin
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: credentialless
  Reporting-Endpoints: csp-endpoint="/api/csp-report"
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-src 'none'; script-src 'self' https://gc.zgo.at https://static.cloudflareinsights.com; style-src 'self'; img-src 'self' https://*.goatcounter.com https://ghchart.rshah.org; media-src 'self'; font-src 'self'; connect-src 'self' https://*.goatcounter.com https://api.github.com https://lingering-surf-6d77.lamasubash107.workers.dev https://portfolio-chat-api.lamasubash107.workers.dev https://raw.githubusercontent.com https://urlhaus-api.abuse.ch https://check.torproject.org https://cloudflareinsights.com; manifest-src 'self'; form-action 'self'; upgrade-insecure-requests; report-to csp-endpoint

# Early Hints — browser starts fetching critical assets before HTML is fully sent
/
  Link: </assets/css/index.css>; rel=preload; as=style
  Link: </assets/css/motion.css>; rel=preload; as=style
  Link: </assets/css/parrot-fx.css>; rel=preload; as=style
  Link: </assets/js/site.js>; rel=preload; as=script
  Link: </assets/images/bg-poster.jpg>; rel=preload; as=image

# HTML pages — always revalidate so updates are instant for all visitors
/
  Cache-Control: no-cache, must-revalidate

/*.html
  Cache-Control: no-cache, must-revalidate

# CSS/JS — no content hashes in filenames so must revalidate on every visit
/assets/css/*
  Cache-Control: no-cache, must-revalidate

/assets/js/*
  Cache-Control: no-cache, must-revalidate

# Images — safe to cache long-term (filenames don't change, content rarely does)
/assets/images/*
  Cache-Control: public, max-age=604800

# Vendor libs — versioned by vendor, safe to cache long-term
/assets/vendor/*
  Cache-Control: public, max-age=31536000, immutable

/assets/media/*
  Cache-Control: public, max-age=604800

# Service worker must always be fresh
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Short cache for dynamic-ish files
/manifest.json
  Cache-Control: public, max-age=86400

/assets/docs/cv/*
  Cache-Control: public, max-age=3600

/.well-known/security.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

# Tool pages — self-contained SPA apps that need inline JS/CSS (localStorage only, no external calls)
/tracker.html
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; base-uri 'self'; object-src 'none'; frame-src 'none'; form-action 'self'

